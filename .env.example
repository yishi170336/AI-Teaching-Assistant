OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3.5:2b
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL_PATH=models/paraphrase-multilingual-MiniLM-L12-v2
REDIS_URL=redis://127.0.0.1:6379/0
SESSION_HISTORY_MESSAGES=100
MEMORY_TURNS=8
MAX_OLLAMA_CONCURRENCY=2
REMOTE_MAX_TOKENS=8192
REMOTE_MAX_CONTINUATIONS=2
MAX_ATTACHMENT_MB=20
MAX_CHAT_ATTACHMENTS=5
INITIAL_CHAPTER_LIMIT=1
QDRANT_URL=
QDRANT_API_KEY=
NEO4J_URI=
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
# 独立部署的 SINA worker：POST multipart image，返回 components/nets/netlist/description JSON
SINA_ENDPOINT=
# PDF-Extract-Kit/MinerU worker 导出的结构化 JSON 目录（每本书 <PDF文件名不含扩展名>.json）
PDF_EXTRACT_KIT_OUTPUT_DIR=
# 本地 CLIP 与 CrossEncoder 模型目录；留空时分别降级为图片文字描述检索和融合重排
CLIP_MODEL_PATH=
RERANK_MODEL_PATH=
MULTIMODAL_IMAGE_LIMIT=0
MULTIMODAL_MIN_IMAGE_AREA=12000
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
